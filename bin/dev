#!/usr/bin/env sh

if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# Fail fast if the committed Tailwind CSS is stale before booting the server
if ! bin/rails tailwindcss:verify; then
  echo "Tailwind verification failed. Aborting." >&2
  exit 1
fi

# Default to port 3001 if not specified (3000 is left for the debuggee app)
export PORT="${PORT:-3001}"

# Let the debug gem allow remote connections,
# but avoid loading until `debugger` is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

exec foreman start -f Procfile.dev "$@"
