<section id="<%= id %>" class="min-h-0">
  <div class="flex h-full flex-col">
    <%# h-10 is shared by every panel header so their bottom borders line up
        across the grid's dividers. %>
    <div class="flex h-10 shrink-0 items-center gap-2 border-b border-slate-800 bg-slate-900/90 px-3">
      <h2 class="text-sm font-semibold tracking-tight text-slate-100">Source</h2>
      <% if snapshot %>
        <span class="shrink-0 rounded px-1.5 py-0.5 text-[10px] uppercase tracking-wide <%= reason_classes %>"><%= snapshot[:reason] %></span>
        <%# rdbg describes the raise ("RuntimeError: boom"); it's the one thing you
            want to read before anything else on an exception stop. %>
        <% if raised? && snapshot[:exception].present? %>
          <span class="truncate font-mono text-xs text-rose-300/80" title="<%= snapshot[:exception] %>"><%= snapshot[:exception] %></span>
        <% end %>
      <% end %>
      <div class="ml-auto shrink-0"><%= render Debug::ControlsComponent.new %></div>
    </div>

    <div class="min-h-0 flex-1 overflow-y-auto" data-controller="source">
      <% if lines.any? %>
        <pre class="overflow-x-auto py-2 text-xs leading-relaxed"><% lines.each do |line| %><div class="flex <%= helpers.source_line_classes(line) %>"<%= ' data-source-target="current"'.html_safe if line.current %>><span class="w-12 shrink-0 select-none pr-3 text-right text-slate-600"><%= line.number %></span><code class="rouge-src whitespace-pre pr-4 <%= "font-medium" if line.current %>"><%= line.html.present? ? line.html.html_safe : (line.text.presence || " ") %></code></div><% end %></pre>
      <% else %>
        <div class="p-6 text-center text-sm text-slate-500">
          <% if abs_path %>Could not read <span class="font-mono"><%= rel_path %></span>.<% else %>No source yet — attach, then trigger a request that hits your breakpoint.<% end %>
        </div>
      <% end %>
    </div>

    <div class="border-t border-slate-800 bg-slate-900/90 px-3 py-2">
      <span class="block truncate font-mono text-xs leading-5 text-slate-400">
        <% if rel_path %><%= rel_path %><%= ":#{focus_line}" if focus_line %><% else %><span class="text-slate-600">Not attached</span><% end %>
      </span>
    </div>
  </div>
</section>
