<div id="<%= id %>" class="min-h-0 overflow-y-auto">
  <div class="sticky top-0 z-10 flex h-10 items-center border-b border-zinc-800 bg-zinc-900/90 px-3">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-zinc-400">Locals</h2>
  </div>

  <% if locals.blank? %>
    <p class="px-3 py-3 text-xs text-zinc-500">No locals in scope.</p>
  <% else %>
    <div class="py-1 text-xs">
      <%= render Debug::VarsComponent.new(vars: locals) %>
    </div>
  <% end %>
</div>
