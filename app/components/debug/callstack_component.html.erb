<div id="<%= id %>" class="min-h-0 overflow-y-auto" data-controller="frame-filter">
  <div class="sticky top-0 z-10 flex h-10 items-center border-b border-slate-800 bg-slate-900/90 px-3">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-400">Call stack</h2>
    <% if filterable? %>
      <button type="button" aria-pressed="false"
              data-action="frame-filter#toggle" data-frame-filter-target="toggle"
              title="Hide frames from gems and the framework"
              class="ml-auto rounded px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-500 transition-colors hover:bg-slate-800 hover:text-slate-300 aria-pressed:bg-sky-500/15 aria-pressed:text-sky-300">app only</button>
    <% end %>
  </div>

  <% if frames.blank? %>
    <p class="px-3 py-3 text-xs text-slate-500">No active frame. Attach and step to a breakpoint.</p>
  <% else %>
    <ol class="px-2 py-2 text-xs">
      <% frames.each_with_index do |frame, i| %>
        <li data-frame-filter-target="frame" data-app="<%= app_frame?(frame) %>" data-selected="<%= selected?(i) %>">
          <button type="button"
                  data-action="stepper#selectFrame"
                  data-stepper-frame-param="<%= i %>"
                  class="<%= frame_classes(i) %>">
            <span class="w-4 shrink-0 self-center text-sky-400"><%= helpers.icon "chevron_right", class: "h-3.5 w-3.5" if selected?(i) %></span>
            <div class="min-w-0">
              <div class="truncate font-medium <%= selected?(i) ? "text-slate-100" : "text-slate-300" %>"><%= frame[:name] %></div>
              <div class="truncate font-mono text-[11px] text-slate-500"><%= rel_path(frame) %>:<%= frame[:line] %></div>
            </div>
          </button>
        </li>
      <% end %>
    </ol>

    <%# Every frame filtered away: the stack is entirely gem/framework code. %>
    <p data-frame-filter-target="empty" class="hidden px-3 pb-3 text-xs text-slate-500">
      No app frames in this stack.
      <button type="button" data-action="frame-filter#toggle" class="text-sky-400 hover:text-sky-300">Show all</button>
    </p>
  <% end %>
</div>
