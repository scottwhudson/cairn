<div id="<%= id %>" class="flex items-center gap-2">
  <span class="flex items-center gap-1.5 rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-300">
    <span class="h-2 w-2 rounded-full <%= state_color %>"></span><%= state %>
  </span>

  <% if attached? %>
    <%# Arming this stops the debuggee at a raise instead of letting it unwind to
        its own error page — so the failing request's browser tab hangs until you
        continue. Worth saying out loud in the tooltip. %>
    <%= button_to debug_session_exception_breakpoint_path, method: (armed? ? :delete : :post),
          title: "Stop at a raise, with the frames still alive. The failing request waits until you continue.",
          aria: {pressed: armed?.to_s}, class: toggle_classes do %>
      break on raise
    <% end %>

    <%= button_to "Detach", debug_session_path, method: :delete,
          class: "rounded-md bg-rose-700 px-3 py-1.5 text-xs font-medium text-white hover:bg-rose-600" %>
  <% end %>
</div>
