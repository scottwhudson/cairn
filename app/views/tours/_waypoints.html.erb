<%# Left panel: the numbered tour steps, each pinned to a file:line. %>
<div class="flex items-center justify-between border-b border-slate-800 px-3 py-2">
  <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-400">Waypoints</h2>
  <%= button_to "Re-import", import_tour_path(tour), method: :post,
        class: "text-[11px] text-slate-500 hover:text-slate-300" %>
</div>

<ol class="min-h-0 flex-1 divide-y divide-slate-800/60 overflow-y-auto">
  <% waypoints.each_with_index do |wp, i| %>
    <li id="waypoint-<%= wp.id %>"
        class="group px-3 py-2 <%= "bg-sky-500/10" if @snapshot && @snapshot[:waypoint_id] == wp.id %>">
      <div class="flex items-start gap-2">
        <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-slate-800 text-[11px] text-slate-400"><%= i + 1 %></span>
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-1.5">
            <span class="font-mono text-xs text-slate-300"><%= wp.location %></span>
            <%= change_kind_badge(wp.change_kind) %>
          </div>
          <% if wp.note.present? %>
            <p class="mt-0.5 text-xs leading-snug text-slate-500"><%= wp.note %></p>
          <% end %>
          <% if wp.author == "reviewer" %>
            <%= button_to "remove bookmark", tour_waypoint_path(tour, wp), method: :delete,
                  class: "mt-1 hidden text-[10px] text-slate-600 hover:text-rose-400 group-hover:inline" %>
          <% end %>
        </div>
      </div>
    </li>
  <% end %>
</ol>

<%# Reviewer-authored ad hoc bookmark. %>
<details class="border-t border-slate-800 px-3 py-2">
  <summary class="cursor-pointer text-[11px] text-slate-500 hover:text-slate-300">+ Add bookmark</summary>
  <%= form_with url: tour_waypoints_path(tour), method: :post, class: "mt-2 space-y-2" do |f| %>
    <div class="flex gap-2">
      <%= f.text_field "waypoint[file]", placeholder: "file", class: "w-full rounded border border-slate-700 bg-slate-800 px-2 py-1 text-xs" %>
      <%= f.number_field "waypoint[line]", placeholder: "line", class: "w-20 rounded border border-slate-700 bg-slate-800 px-2 py-1 text-xs" %>
    </div>
    <%= f.text_field "waypoint[note]", placeholder: "note (optional)", class: "w-full rounded border border-slate-700 bg-slate-800 px-2 py-1 text-xs" %>
    <%= f.submit "Add", class: "rounded bg-slate-700 px-2 py-1 text-xs text-slate-100 hover:bg-slate-600" %>
  <% end %>
</details>
