<% content_for :title, "New tour" %>
<div class="mx-auto max-w-2xl">
  <h1 class="mb-4 text-xl font-semibold">New tour</h1>

  <%= form_with model: @tour, class: "space-y-4" do |f| %>
    <% if @tour.errors.any? %>
      <div class="rounded border border-rose-800 bg-rose-900/30 p-3 text-sm text-rose-200">
        <%= @tour.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :title, class: "block text-sm text-slate-300" %>
      <%= f.text_field :title, class: input_classes %>
    </div>
    <div>
      <%= f.label :description, class: "block text-sm text-slate-300" %>
      <%= f.text_area :description, rows: 2, class: input_classes %>
    </div>
    <div>
      <%= f.label :repo_path, "Repo path (absolute)", class: "block text-sm text-slate-300" %>
      <%= f.text_field :repo_path, class: input_classes, placeholder: Rails.root.to_s %>
      <p class="mt-1 text-xs text-slate-500">The checkout of the app under review. A <code>tour.yml</code> here is auto-imported.</p>
    </div>
    <div>
      <%= f.label :entrypoint, "Entrypoint (relative to repo path)", class: "block text-sm text-slate-300" %>
      <%= f.text_field :entrypoint, class: input_classes, placeholder: "script/sample_app/run.rb" %>
    </div>
    <div>
      <%= f.label :git_ref, "Git ref (optional)", class: "block text-sm text-slate-300" %>
      <%= f.text_field :git_ref, class: input_classes %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Create tour", class: "rounded-md bg-sky-600 px-3 py-2 text-sm font-medium text-white hover:bg-sky-500" %>
      <%= link_to "Cancel", tours_path, class: "px-3 py-2 text-sm text-slate-400 hover:text-slate-200" %>
    </div>
  <% end %>
</div>

<% content_for :head do %>
<% end %>
