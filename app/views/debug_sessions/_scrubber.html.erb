<%# Bottom: step controls + history scrubber (record/replay, no re-execution). %>
<%
  total ||= 0
  index ||= 0
  has_history = total.positive?
%>
<div class="flex items-center gap-3 rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-2"
     data-scrubber-target="bar"
     data-scrubber-index-value="<%= index %>"
     data-scrubber-total-value="<%= total %>">

  <div class="flex items-center gap-1">
    <button data-action="scrubber#stepBack" title="Step back (←)"
            class="rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700">⤺ back</button>
    <button data-action="scrubber#stepOver" title="Step over (↓)"
            class="rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700">↷ over</button>
    <button data-action="scrubber#stepIn" title="Step in"
            class="rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700">↴ in</button>
    <button data-action="scrubber#continue" title="Continue to next breakpoint (→)"
            class="rounded bg-sky-700 px-2.5 py-1.5 text-sm font-medium text-white hover:bg-sky-600">▷ continue</button>
  </div>

  <div class="flex flex-1 items-center gap-2">
    <input type="range" min="0" max="<%= [total - 1, 0].max %>" value="<%= index %>"
           step="1" <%= "disabled" unless has_history %>
           data-scrubber-target="slider" data-action="scrubber#scrub"
           class="h-1.5 w-full cursor-pointer appearance-none rounded-full bg-slate-700 accent-sky-500 disabled:opacity-40">
    <span class="shrink-0 whitespace-nowrap font-mono text-xs text-slate-400"
          data-scrubber-target="position">
      <%= has_history ? "#{index + 1} / #{total}" : "0 / 0" %>
    </span>
  </div>
</div>
