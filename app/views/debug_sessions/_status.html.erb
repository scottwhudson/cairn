<%# Session state pill + start/stop control. %>
<% active = Debug::SessionRegistry.active?(tour.id) %>
<div class="flex items-center gap-2">
  <% color = { "running" => "bg-emerald-500", "starting" => "bg-amber-400 animate-pulse",
               "errored" => "bg-rose-500", "stopped" => "bg-slate-500" }[state.to_s] || "bg-slate-600" %>
  <span class="flex items-center gap-1.5 rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-300">
    <span class="h-2 w-2 rounded-full <%= color %>"></span><%= state %>
  </span>

  <% if active %>
    <%= button_to "Stop", tour_debug_session_path(tour), method: :delete,
          class: "rounded-md bg-rose-700 px-3 py-1.5 text-xs font-medium text-white hover:bg-rose-600" %>
  <% else %>
    <%= button_to "Start session", tour_debug_session_path(tour), method: :post,
          class: "rounded-md bg-emerald-700 px-3 py-1.5 text-xs font-medium text-white hover:bg-emerald-600" %>
  <% end %>
</div>
