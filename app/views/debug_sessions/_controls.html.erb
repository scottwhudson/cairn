<%# Bottom: execution controls. %>
<div class="flex items-center gap-3 rounded-lg border border-slate-800 bg-slate-900/60 px-3 py-2">
  <div class="flex items-center gap-1">
    <button data-action="stepper#stepOver" title="Step over (↓)"
            class="rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700">↷ over</button>
    <button data-action="stepper#stepIn" title="Step in (↑)"
            class="rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700">↴ in</button>
    <button data-action="stepper#stepOut" title="Step out (⇧↑)"
            class="rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700">↥ out</button>
    <button data-action="stepper#continue" title="Continue to next breakpoint (→)"
            class="rounded bg-sky-700 px-2.5 py-1.5 text-sm font-medium text-white hover:bg-sky-600">▷ continue</button>
  </div>
</div>
