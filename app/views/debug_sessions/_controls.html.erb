<%# Execution controls. Rendered into the source panel's footer, under the code
    they step through. %>
<div class="flex items-center gap-1">
  <button data-action="stepper#stepOver" title="Step over (↓)"
          class="inline-flex items-center gap-1.5 rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700"><%= icon "arrow_right", class: "h-4 w-4 text-slate-400" %> over</button>
  <button data-action="stepper#stepIn" title="Step in (↑)"
          class="inline-flex items-center gap-1.5 rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700"><%= icon "arrow_down", class: "h-4 w-4 text-slate-400" %> in</button>
  <button data-action="stepper#stepOut" title="Step out (⇧↑)"
          class="inline-flex items-center gap-1.5 rounded bg-slate-800 px-2.5 py-1.5 text-sm hover:bg-slate-700"><%= icon "arrow_up", class: "h-4 w-4 text-slate-400" %> out</button>
  <button data-action="stepper#continue" title="Continue to next breakpoint (→)"
          class="inline-flex items-center gap-1.5 rounded bg-sky-700 px-2.5 py-1.5 text-sm font-medium text-white hover:bg-sky-600"><%= icon "play", class: "h-4 w-4" %> continue</button>
</div>
