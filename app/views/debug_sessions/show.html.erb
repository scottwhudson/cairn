<% content_for :title, "Cairn Debugger" %>
<%= turbo_stream_from Debug::SessionBroadcaster::STREAM, channel: "DebugChannel" %>

<%
  active    = @session.attached?
  repo_path = @session.client&.repo_path
%>

<%# Session state + attach live in the layout's header, alongside the wordmark. %>
<% content_for :header_actions do %>
  <%= render Debug::StatusComponent.new(state: (active ? @session.state : "idle"), client: @session.client) %>
  <% unless active %>
    <%= render "debug_sessions/connect_drawer" %>
  <% end %>
<% end %>

<div class="flex h-full flex-col"
     data-controller="stepper"
     data-stepper-steps-url-value="<%= debug_session_steps_path %>"
     data-stepper-selected-frame-url-value="<%= debug_session_selected_frame_path %>"
     data-stepper-evaluations-url-value="<%= debug_session_evaluations_path %>">

  <%# An empty stand-in, so an error always has something to replace. %>
  <%= tag.div id: Debug::FlashComponent::ID %>

  <%# ── panels ────────────────────────────────────────────────────────
      One framed grid rather than free-floating cards: panels butt against each
      other and are separated by draggable hairlines. Each resizable track is
      sized from a custom property that the splitter controller rewrites; the
      neighbouring `1fr` track soaks up the slack. Each panel component renders
      its own grid cell, id and all. %>
  <div class="grid min-h-0 flex-1 overflow-hidden bg-zinc-900/40"
       style="grid-template-rows: minmax(0, 1fr)<%= " auto minmax(0, var(--repl-h, 12rem))" if active %>">

    <div class="grid min-h-0" style="grid-template-columns: minmax(0, 1fr) auto minmax(0, var(--side-w, 22rem))">
      <%= render Debug::SourceComponent.new(snapshot: @snapshot, repo_path: repo_path) %>

      <%= render "debug_sessions/gutter", axis: "col", variable: "--side-w", edge: "right", min: 240 %>

      <aside class="grid min-h-0" style="grid-template-rows: minmax(0, var(--callstack-h, 1fr)) auto minmax(0, 1fr)">
        <%= render Debug::CallstackComponent.new(snapshot: @snapshot, repo_path: repo_path) %>

        <%= render "debug_sessions/gutter", axis: "row", variable: "--callstack-h", edge: "top", min: 80 %>

        <%= render Debug::LocalsComponent.new(snapshot: @snapshot) %>
      </aside>
    </div>

    <%# ── repl ──────────────────────────────────────────────────────── %>
    <% if active %>
      <%= render "debug_sessions/gutter", axis: "row", variable: "--repl-h", edge: "bottom", min: 80 %>

      <%= render Debug::ReplComponent.new(stopped: @session.state == :stopped) %>
    <% end %>
  </div>
</div>
