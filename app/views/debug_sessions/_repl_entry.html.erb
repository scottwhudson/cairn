<%# One console entry: the expression that was run and its result. A structured
    result is rendered as a var row so it can be expanded like a local. %>
<div class="border-l-2 <%= result[:error] ? "border-rose-700/60" : "border-slate-700/70" %> pl-2">
  <div class="text-slate-400"><span class="select-none text-slate-600">»</span> <%= expression %></div>
  <% if result[:error] %>
    <div class="pl-3 text-rose-300/90"><%= result[:value] %></div>
  <% else %>
    <%= render "debug_sessions/var",
          var: { name: "⇒", value: result[:value], type: result[:type], ref: result[:ref] } %>
  <% end %>
</div>
