<%# locals: () %>
<%# Attach to a running rdbg DAP server. The target server must have been started
    with `rdbg --open --port <PORT> --nonstop bin/rails server` (or similar).
    Rendered inside the connect drawer, so it stacks rather than sits in a grid.
    Fields pre-fill from a .cairnrc file when one is present — see Debug::Config. %>
<% config = Debug::Config.current %>
<%= form_with url: debug_session_path, method: :post, scope: :debug_session, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :host, "Host", class: "mb-1 block text-xs text-zinc-400" %>
    <%= f.text_field :host, value: config.host,
          class: "w-full rounded border border-zinc-700 bg-zinc-950 px-2 py-1.5 font-mono text-sm" %>
  </div>

  <div>
    <%= f.label :port, "Port", class: "mb-1 block text-xs text-zinc-400" %>
    <%= f.number_field :port, value: config.port.presence || "12345", data: {drawer_target: "autofocus"},
          class: "w-full rounded border border-zinc-700 bg-zinc-950 px-2 py-1.5 font-mono text-sm" %>
  </div>

  <div>
    <%= f.label :repo_path, "Repo path", class: "mb-1 block text-xs text-zinc-400" %>
    <%= f.text_field :repo_path, value: config.repo_path, placeholder: "/Users/you/code/target-app",
          class: "w-full rounded border border-zinc-700 bg-zinc-950 px-2 py-1.5 font-mono text-sm" %>
    <p class="mt-1 text-[11px] leading-relaxed text-zinc-500">
      The target's source root. Optional — without it, paths show in full and the
      call stack can't tell your code from gem code.
    </p>
  </div>

  <% if config.loaded? %>
    <p class="text-[11px] leading-relaxed text-zinc-500">
      Defaults loaded from <span class="font-mono text-zinc-400"><%= config.path %></span>.
    </p>
  <% end %>

  <%= f.submit "Attach", class: "w-full rounded-md bg-emerald-700 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-600" %>

  <p class="text-xs leading-relaxed text-zinc-500">
    Start the target with
    <span class="font-mono text-zinc-400">rdbg --open --port &lt;PORT&gt; --nonstop bin/rails server</span>,
    then attach here and trigger a request.
  </p>
<% end %>
