<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Cairn" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cairn">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%# Rouge syntax-highlighting theme for the source pane. %>
    <%= tag.style source_theme_css.html_safe %>
    <%= javascript_importmap_tags %>
  </head>

  <%# A column: fixed-height header, then a main that takes whatever's left, so the
      debugger panes can fill the viewport without a hardcoded height. %>
  <body class="flex h-full flex-col bg-slate-950 text-slate-100 antialiased">
    <header class="flex shrink-0 items-center gap-4 border-b border-slate-800 bg-slate-900/80 px-5 py-3">
      <%= link_to root_path, class: "inline-flex items-center gap-2 font-semibold tracking-tight text-slate-100 hover:text-white" do %>
        <%= icon "stones", class: "h-5 w-5 text-emerald-400" %>
        Cairn
      <% end %>
      <div class="ml-auto flex items-center gap-3"><%= yield :header_actions %></div>
    </header>

    <%# Toasts: stacked bottom-right, each fading itself out after a few seconds. %>
    <div class="pointer-events-none fixed inset-x-0 bottom-0 z-50 flex flex-col items-end gap-2 p-5">
      <% {notice => "border-emerald-800 bg-emerald-900/90 text-emerald-100",
          alert => "border-rose-800 bg-rose-900/90 text-rose-100"}.each do |message, palette| %>
        <% if message.present? %>
          <div data-controller="autohide" role="status"
               class="pointer-events-auto flex max-w-sm items-start gap-3 rounded-lg border px-4 py-2.5 text-sm shadow-lg <%= palette %>">
            <span><%= message %></span>
            <button type="button" data-action="autohide#dismiss" aria-label="Dismiss"
                    class="-mr-1 shrink-0 rounded p-0.5 opacity-60 hover:bg-white/10 hover:opacity-100">✕</button>
          </div>
        <% end %>
      <% end %>
    </div>

    <main class="min-h-0 flex-1 p-5">
      <%= yield %>
    </main>
  </body>
</html>
