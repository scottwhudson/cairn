<% content_for :title, "Trace: #{@trace_run.label}" %>
<div class="mx-auto max-w-4xl">
  <div class="mb-4 flex items-center gap-3">
    <h1 class="text-xl font-semibold">Trace: <%= @trace_run.label %></h1>
    <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-400"><%= @trace_run.event_count %> events</span>
    <%= link_to "All traces", trace_runs_path, class: "ml-auto text-sm text-slate-400 hover:text-slate-200" %>
  </div>

  <div class="overflow-x-auto rounded-lg border border-slate-800 bg-slate-900/40">
    <table class="w-full text-xs">
      <thead class="border-b border-slate-800 text-left text-slate-500">
        <tr><th class="px-3 py-2">#</th><th class="px-3 py-2">event</th><th class="px-3 py-2">method</th><th class="px-3 py-2">loc</th></tr>
      </thead>
      <tbody class="divide-y divide-slate-800/60">
        <% @trace_run.events.each_with_index do |e, i| %>
          <tr>
            <td class="px-3 py-1 text-slate-600"><%= i + 1 %></td>
            <td class="px-3 py-1 font-mono text-slate-400"><%= e["event"] %></td>
            <td class="px-3 py-1 font-mono text-slate-200" style="padding-left: <%= 12 + e["depth"].to_i * 14 %>px"><%= e["method"] %></td>
            <td class="px-3 py-1 font-mono text-slate-500"><%= e["file"] %>:<%= e["line"] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
